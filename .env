# Ambiente de desenvolvimento local
PORT=3001
NODE_ENV=development
DATABASE_URL=./database.json
FRONTEND_URL=http://localhost:3000
JWT_SECRET=dev-secret-key-local-only
SESSION_SECRET=dev-session-secret-local-only

# Pagar.me - OBRIGATÓRIO para criar splits
# Obtenha sua chave em: https://dashboard.pagar.me/
# IMPORTANTE: Cole a chave COMPLETA sem asteriscos (*)
