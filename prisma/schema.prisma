// Schema Prisma - Pag2Pay Gateway de Pagamento
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUÁRIOS ====================

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  role             String    @default("user") // user, admin
  commissionRate   Int?      @default(70)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relações
  products         Product[]
  orders           Order[]
  affiliations     Affiliation[]
  commissions      Commission[]
  bankAccounts     BankAccount[]
  withdrawals      Withdrawal[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

// ==================== ADMINISTRADORES DA PLATAFORMA ====================

model PlatformAdmin {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String
  name               String
  userType           String   @default("platform-admin")
  twoFactorSecret    String?  // Secret para TOTP (Google Authenticator)
  twoFactorEnabled   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email])
  @@map("platform_admins")
}

// ==================== USUÁRIOS DA PLATAFORMA (KYC) ====================

model PlatformUser {
  id                  Int       @id @default(autoincrement())
  name                String
  email               String    @unique
  phone               String?
  accountType         String    // pf, pj
  cpf                 String?   @unique
  cnpj                String?   @unique
  status              String    @default("pending") // pending, approved, rejected
  pendingReason       String?

  // KYC
  kyc                 Json?

  // Endereço PF
  enderecoPF          Json?

  // Documentos
  documentos          Json?

  // Dados Bancários
  dadosBancarios      Json?

  // Split/Recipient
  splitStatus         String?
  splitAccountId      String?
  splitCreatedAt      DateTime?

  // Controles
  withdrawalLocked    Boolean   @default(false)
  totalProducts       Int       @default(0)
  totalSales          Decimal   @default(0) @db.Decimal(10, 2)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([email])
  @@index([cpf])
  @@index([cnpj])
  @@index([status])
  @@index([splitAccountId])
  @@map("platform_users")
}

// ==================== PRODUTOS ====================

model Product {
  id                String    @id @default(uuid())
  code              String    @unique
  name              String
  description       String?   @db.Text
  category          String
  productType       String?
  price             Decimal   @db.Decimal(10, 2)
  image             String?
  salesPageUrl      String?
  supportEmail      String?
  warrantyDays      Int       @default(0)

  // Produtor
  producerId        String
  producerName      String
  producer          User      @relation(fields: [producerId], references: [id], onDelete: Cascade)

  // Status de aprovação
  approvalStatus    String    @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO, SUSPENSO
  approvedAt        DateTime?
  rejectedAt        DateTime?
  suspendedAt       DateTime?
  rejectionReason   String?
  suspensionReason  String?

  // Turbina Score
  turbinaScore      Int       @default(0)

  // Configurações de Afiliação
  affiliateConfig   Json?
  affiliateCommission Int?    @default(0)

  // Configurações de Checkout
  checkoutConfig    Json?
  paymentMethods    Json?

  // Planos
  plans             Json?     @default("[]")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relações
  orders            Order[]
  affiliations      Affiliation[]

  @@index([producerId])
  @@index([approvalStatus])
  @@index([category])
  @@index([code])
  @@index([createdAt])
  @@map("products")
}

// ==================== PRODUTOS EXCLUÍDOS ====================

model DeletedProduct {
  id                String    @id @default(uuid())
  originalId        String    // ID original do produto
  code              String
  name              String
  description       String?   @db.Text
  category          String
  productType       String?
  price             Decimal   @db.Decimal(10, 2)
  image             String?

  // Dados do produtor
  producerId        String
  producerName      String

  // Motivo da exclusão
  deletionReason    String
  deletedBy         String
  approvedBy        String
  deletedAt         DateTime  @default(now())

  // Dados originais (JSON completo)
  originalData      Json

  @@index([originalId])
  @@index([producerId])
  @@index([deletedAt])
  @@map("deleted_products")
}

// ==================== SOLICITAÇÕES DE EXCLUSÃO ====================

model DeletionRequest {
  id                Int       @id @default(autoincrement())
  productId         String
  productName       String
  productCategory   String
  productPrice      Decimal   @db.Decimal(10, 2)

  userId            String
  userName          String
  reason            String

  status            String    @default("pending") // pending, approved, rejected
  requestedAt       DateTime  @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewerNotes     String?

  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([requestedAt])
  @@map("deletion_requests")
}

// ==================== PEDIDOS/VENDAS ====================

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique

  // Cliente
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  customerName      String
  customerEmail     String
  customerPhone     String?

  // Produto
  productId         String
  product           Product     @relation(fields: [productId], references: [id])
  productName       String
  productPrice      Decimal     @db.Decimal(10, 2)

  // Pagamento
  amount            Decimal     @db.Decimal(10, 2)
  paymentMethod     String      // pix, boleto, creditCard, afterPay
  paymentStatus     String      @default("pending") // pending, paid, cancelled, refunded

  // Gateway
  gatewayId         String?     // ID na Pagar.me, etc
  gatewayData       Json?

  // Endereço de entrega (se aplicável)
  shippingAddress   Json?
  trackingCode      String?

  // Datas
  paidAt            DateTime?
  cancelledAt       DateTime?
  refundedAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relações
  transactions      Transaction[]
  commissions       Commission[]

  @@index([userId])
  @@index([productId])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([createdAt])
  @@map("orders")
}

// ==================== TRANSAÇÕES ====================

model Transaction {
  id                String    @id @default(uuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  gatewayId         String?   // ID no gateway de pagamento
  amount            Decimal   @db.Decimal(10, 2)
  status            String    // pending, approved, cancelled, refunded
  paymentMethod     String

  metadata          Json?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderId])
  @@index([gatewayId])
  @@index([status])
  @@map("transactions")
}

// ==================== AFILIAÇÕES ====================

model Affiliation {
  id                String    @id @default(uuid())

  // Afiliado
  affiliateId       String
  affiliate         User      @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  affiliateName     String

  // Produto
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productName       String

  // Status
  status            String    @default("pending") // pending, approved, rejected
  commissionRate    Int       // Percentual de comissão

  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([affiliateId, productId])
  @@index([affiliateId])
  @@index([productId])
  @@index([status])
  @@map("affiliations")
}

// ==================== COMISSÕES ====================

model Commission {
  id                String    @id @default(uuid())

  // Venda relacionada
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id])

  // Beneficiário
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  userType          String    // producer, affiliate, platform

  // Valores
  amount            Decimal   @db.Decimal(10, 2)
  rate              Int       // Percentual

  status            String    @default("pending") // pending, paid, cancelled
  paidAt            DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("commissions")
}

// ==================== CONTAS BANCÁRIAS ====================

model BankAccount {
  id                String    @id @default(uuid())

  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankCode          String
  bankName          String
  accountType       String    // Corrente, Poupança
  agency            String
  accountNumber     String
  accountDigit      String?

  holderName        String
  holderDocument    String    // CPF/CNPJ

  isPrimary         Boolean   @default(false)
  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relações
  withdrawals       Withdrawal[]

  @@index([userId])
  @@map("bank_accounts")
}

// ==================== SAQUES ====================

model Withdrawal {
  id                String      @id @default(uuid())

  userId            String
  user              User        @relation(fields: [userId], references: [id])

  bankAccountId     String
  bankAccount       BankAccount @relation(fields: [bankAccountId], references: [id])

  amount            Decimal     @db.Decimal(10, 2)
  fee               Decimal     @default(0) @db.Decimal(10, 2)
  netAmount         Decimal     @db.Decimal(10, 2)

  status            String      @default("pending") // pending, processing, completed, rejected

  requestedAt       DateTime    @default(now())
  processedAt       DateTime?
  completedAt       DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?

  gatewayId         String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
  @@map("withdrawals")
}

// ==================== ACHIEVEMENTS/CONQUISTAS ====================

model Achievement {
  id                String    @id @default(uuid())
  name              String
  description       String
  icon              String
  category          String

  // Requisitos
  requirements      Json

  // Recompensas
  rewards           Json?

  isActive          Boolean   @default(true)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relações
  userAchievements  UserAchievement[]

  @@map("achievements")
}

// ==================== CONQUISTAS DOS USUÁRIOS ====================

model UserAchievement {
  id                String      @id @default(uuid())

  userId            String
  achievementId     String
  achievement       Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt        DateTime    @default(now())
  progress          Int         @default(0)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ==================== CONFIGURAÇÕES DA PLATAFORMA ====================

model PlatformSettings {
  id                String    @id @default(uuid())
  key               String    @unique
  value             Json

  updatedAt         DateTime  @updatedAt

  @@map("platform_settings")
}

// ==================== LOGS ====================

model Log {
  id                String    @id @default(uuid())
  level             String    // info, warn, error
  message           String
  metadata          Json?

  userId            String?
  endpoint          String?

  createdAt         DateTime  @default(now())

  @@index([level])
  @@index([userId])
  @@index([createdAt])
  @@map("logs")
}
